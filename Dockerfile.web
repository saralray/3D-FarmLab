FROM node:20-bookworm-slim AS build

WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .

ARG VITE_PUBLIC_VIEWER_MODE=false
ARG VITE_GOOGLE_FORM_URL
ARG VITE_GOOGLE_SHEET_QUEUE_URL
ENV VITE_PUBLIC_VIEWER_MODE=$VITE_PUBLIC_VIEWER_MODE
ENV VITE_GOOGLE_FORM_URL=$VITE_GOOGLE_FORM_URL
ENV VITE_GOOGLE_SHEET_QUEUE_URL=$VITE_GOOGLE_SHEET_QUEUE_URL

RUN npm run build

FROM node:20-bookworm-slim AS runtime

ENV NODE_ENV=production
ENV PORT=5173

WORKDIR /app

RUN groupadd --system printfarm \
  && useradd --system --gid printfarm --home-dir /app printfarm

COPY package.json ./

# The server's runtime dependencies are the pg client and the mqtt client (used
# for Bambu printer commands). Keep these versions in sync with package.json.
# The build stage (npm ci) covers the rest.
RUN npm install pg@8.21.0 mqtt@5.15.1 --no-save --no-audit --no-fund \
  && npm cache clean --force

COPY --from=build /app/dist ./dist
COPY server ./server

USER printfarm

EXPOSE 5173

CMD ["node", "server/app.js"]
