FROM node:20-bookworm-slim AS build

WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .

ARG VITE_PUBLIC_VIEWER_MODE=false
ENV VITE_PUBLIC_VIEWER_MODE=$VITE_PUBLIC_VIEWER_MODE

# The admin password is no longer baked into the bundle — it is set through the
# website on first run and stored server-side (app_settings). No build arg needed.

RUN npm run build

FROM node:20-bookworm-slim AS runtime

ENV NODE_ENV=production
ENV PORT=5173

# Git commit SHA this image was built from (passed by CI, defaults to "dev" for
# local builds). The server exposes it as the running version so the admin
# "update available" check can compare it against the latest published commit.
ARG APP_VERSION=dev
ENV APP_VERSION=$APP_VERSION

WORKDIR /app

# ffmpeg transcodes the Bambu H2/X1-class RTSP-over-TLS camera (port 322) to
# AV1 for the live-view hub (server/bambuCamera.js) and still grabs JPEG
# snapshots from it; the A1/P1 port-6000 camera path needs no external binary.
# Bookworm's ffmpeg (7:5.1.x) is built with --enable-libsvtav1, but a mirror
# swap or base-image bump could silently drop it, so assert it's actually
# present at build time rather than discovering a missing encoder at runtime
# against a live printer.
RUN set -e; \
  apt-get update; \
  apt-get install -y --no-install-recommends ffmpeg; \
  rm -rf /var/lib/apt/lists/*; \
  if ! ffmpeg -hide_banner -encoders 2>&1 | grep -q libsvtav1; then \
    echo "FATAL: ffmpeg image is missing the libsvtav1 AV1 encoder" >&2; \
    exit 1; \
  fi

RUN groupadd --system printfarm \
  && useradd --system --gid printfarm --home-dir /app printfarm

# The server's runtime dependencies are the pg client, the mqtt client (used for
# Bambu printer commands), busboy (multipart parsing for the in-app print-request
# form upload), ioredis (optional Redis acceleration layer — sessions, login
# rate-limit and live-telemetry cache; inert when REDIS_URL is unset), and the
# SAML SSO XML stack (xml-crypto + @xmldom/xmldom + xpath, used by
# server/samlSp.js to verify signed SAML assertions). Keep these versions in sync
# with package.json. The build stage (npm ci) covers the rest.
#
# Installed *before* copying the project package.json on purpose: with that
# package.json present, npm would try to resolve the whole frontend dependency
# tree (which has peer-dep conflicts, e.g. @dnd-kit/core needs react-dom) even
# though none of it is needed at runtime. Installing the leaf packages into an
# empty dir keeps this image to just the server deps.
RUN npm install pg@8.21.0 mqtt@5.15.1 busboy@1.6.0 ioredis@5.4.1 \
      xml-crypto@6.0.1 @xmldom/xmldom@0.8.10 xpath@0.0.34 \
      --no-save --no-audit --no-fund \
  && npm cache clean --force

# Needed at runtime for "type": "module" — the server is ES modules.
COPY package.json ./

COPY --from=build /app/dist ./dist
COPY server ./server

USER printfarm

EXPOSE 5173

CMD ["node", "server/app.js"]
