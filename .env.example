POSTGRES_DB="printfarm"
POSTGRES_USER="printfarm_app"
POSTGRES_PASSWORD="replace_with_a_long_random_password"
HTTP_PORT="8080"
VITE_PUBLIC_VIEWER_MODE="false"
PRINTER_OFFLINE_GRACE_SECONDS="30"
PRINTER_POLL_INTERVAL_MS="2000"
PRINTER_REQUEST_TIMEOUT_MS="3000"
# Public link to your Google Sheet feeding the queue (server fetches it as CSV).
VITE_GOOGLE_SHEET_QUEUE_URL="https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/edit?usp=sharing"
# Public link to the Google Form users submit print requests through.
VITE_GOOGLE_FORM_URL="https://docs.google.com/forms/d/e/YOUR_FORM_ID/viewform?usp=dialog"
