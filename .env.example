POSTGRES_DB="printfarm"
POSTGRES_USER="printfarm_app"
POSTGRES_PASSWORD="replace_with_a_long_random_password"
HTTP_PORT="8080"
# nginx server_name. Leave as "_" to match any Host header, or set one or more
# space-separated names/IPs for name-based virtual hosting, e.g.
# "printfarm.example.com 203.0.113.5". Note: server_name matches the hostname
# only — the port is not part of it (that's HTTP_PORT above + "listen 80" in the
# container), so do not append ":port" here.
SERVER_NAME="_"
VITE_PUBLIC_VIEWER_MODE="false"

# NOTE: the admin password is no longer configured here. It is set through the
# website the first time someone opens /admin (a one-time setup screen) and is
# stored server-side in the database — nothing is baked into the frontend bundle.

# Slicer-upload proxy. nginx routes /printers/ on the main site to this service,
# so a slicer (Orca etc.) can push sliced files using the same domain as the
# dashboard — point its OctoPrint host at http://<domain>/printers/<printerId>
# (no separate port). Authenticated with named API keys minted in Settings →
# Slicer Upload; the key is the only guard now that the endpoint is on the public
# site. SLICER_PROXY_PORT is the container's internal listen port only — it is no
# longer published to the host, since nginx reaches it over the compose network.
SLICER_PROXY_PORT="8091"
# Shared by the web and slicer-proxy services. Two uses:
#  - web: fallback public origin for OAuth redirect_uri / SAML ACS URLs, used
#    only when no admin override is set in Settings → Sign-in ("SSO public
#    URL", which takes precedence over this).
#  - slicer-proxy: the slicer's "Device" tab opens its base URL, which redirects
#    to the dashboard's printer-management page (with operator access).
# Behind nginx both redirects stay on the request's own domain automatically;
# set APP_BASE_URL only to force a specific origin, e.g. a different host or
# HTTPS scheme:
# APP_BASE_URL="https://printfarm.example.com"
APP_BASE_URL=""

# Secret used to sign the short-lived operator-grant token a slicer's "Device"
# tab carries into the dashboard. The slicer-proxy mints the token and the web
# server verifies it, so both services must share this exact value. Leave it
# empty to disable the auto-operator grant entirely (slicer users then land as
# viewers / log in normally). Generate a long random value, e.g.:
#   node -e "console.log(require('node:crypto').randomBytes(32).toString('hex'))"
SLICER_GRANT_SECRET=""

# Login sessions are stored server-side and carried in an HttpOnly cookie. Set
# this to "true" once the site is served over HTTPS so the session cookie is
# marked Secure (it is left non-Secure by default so login still works over the
# plain-http :8080 deployment; the cookie is Secure automatically whenever a
# request arrives with X-Forwarded-Proto: https).
SESSION_COOKIE_SECURE="false"

# HTTP security headers (web service). The web server sends a Content-Security-
# Policy tuned for the built SPA (script-src 'self' — the bundle has no inline
# scripts) plus HSTS over HTTPS. Defaults are safe; override only if needed:
#   CONTENT_SECURITY_POLICY  override the whole CSP string; "off" disables it.
#   CSP_REPORT_ONLY="true"   emit the CSP as report-only (observe violations in
#                            the browser console without enforcing) — use this to
#                            validate a custom policy before turning it on.
#   HSTS_MAX_AGE             Strict-Transport-Security max-age in seconds, sent
#                            only over HTTPS (X-Forwarded-Proto: https). 0 = off.
#                            Default 15552000 (180 days), includeSubDomains.
CONTENT_SECURITY_POLICY=""
CSP_REPORT_ONLY="false"
HSTS_MAX_AGE="15552000"

# Encryption key for printer connection secrets at rest. This is ONE master key
# for the whole deployment, NOT a per-printer secret: each printer still has its
# own different access code (entered in the UI, stored per row in api_key_header)
# — this single key just encrypts all of them in the database. The LAN access
# code / API key in each printer row (api_key_header) is the password used to
# reach that printer's camera, MQTT and FTP — set this so a leaked database dump
# doesn't expose them all in clear. AES-256-GCM; the same key MUST be set on the web,
# slicer-proxy AND poller services or Bambu camera/MQTT/FTP auth breaks. Accepts
# a 64-char hex value, a 32-byte base64 value, or any passphrase (hashed to 32
# bytes). Leave EMPTY to disable encryption (secrets stored as plaintext, the
# previous behavior). Once set, existing plaintext rows are encrypted on startup.
# Generate one with:
#   node -e "console.log(require('node:crypto').randomBytes(32).toString('hex'))"
# Changing or losing this key makes already-encrypted secrets unrecoverable
# (re-enter each printer's access code), so store it safely.
PRINTER_SECRET_KEY=""

# Model uploads from the /request form are stored in Postgres. Only STL / 3MF /
# OBJ are accepted. QUEUE_UPLOAD_MAX_BYTES caps one upload (default 50 MB); the
# nginx /api/queue/submit location lifts its body cap to match.
QUEUE_UPLOAD_MAX_BYTES="52428800"

# Optional Redis acceleration layer. Redis is NOT required — leave this empty and
# the stack runs exactly as before (sessions and login throttling fall back to
# Postgres / in-memory, telemetry stays Postgres-only). Set it to turn Redis into
# a cache and shared counter in FRONT of Postgres (Postgres stays the source of
# truth, so a Redis outage degrades gracefully rather than failing requests). This
# matters at scale: it lets the web tier run multiple instances with one shared
# login rate-limit, offloads per-request session lookups, and serves hot printer
# telemetry without hammering Postgres. Point it at the bundled redis service:
#   REDIS_URL="redis://redis:6379"
# (add /0 for a specific db, or redis://:<password>@host:6379 if you set one).
REDIS_URL=""

# Postgres connection hardening (applies to web, slicer-proxy, poller, exporter).
# DATABASE_POOL_MAX is the per-process pool size for the Node services (web +
# slicer-proxy) — size it so (replicas x pool max) stays under Postgres
# max_connections (default 100). The timeouts are safety guards in milliseconds
# (0 disables one): STATEMENT caps a runaway query rather than letting it pin a
# pooled connection; IDLE_TX reaps a connection left mid-transaction so it can't
# hold locks; CONNECT bounds a stalled connect. The poller and exporter apply the
# same timeouts to their psycopg connections. The 30s statement timeout is
# deliberately generous so the schema/migration advisory-lock wait at startup is
# never killed.
DATABASE_POOL_MAX="10"
DATABASE_POOL_IDLE_MS="30000"
DATABASE_CONNECT_TIMEOUT_MS="5000"
DATABASE_STATEMENT_TIMEOUT_MS="30000"
DATABASE_IDLE_TX_TIMEOUT_MS="60000"

# Observability (web service). LOG_LEVEL sets the minimum level (debug|info|warn|
# error). LOG_FORMAT="json" emits one JSON object per log line for an aggregator
# (Loki/ELK); the default "text" stays human-readable in `docker compose logs`.
# LOG_HTTP controls the per-request access log: "sample" (default) logs every
# 4xx/5xx but not successful reads, "all" logs every request, "off" disables it.
# The web tier's Prometheus request metrics are always served at the internal
# /metrics (scraped over the compose network; nginx returns 404 publicly).
LOG_LEVEL="info"
LOG_FORMAT="text"
LOG_HTTP="sample"

PRINTER_OFFLINE_GRACE_SECONDS="30"
PRINTER_POLL_INTERVAL_MS="2000"
PRINTER_REQUEST_TIMEOUT_MS="3000"
# The poller now writes a printer row to the database only when its telemetry
# actually changed since the last write, instead of rewriting the whole row every
# poll cycle — at 50-200 printers that per-cycle rewrite was the dominant source
# of database write load and table bloat. This caps how long an unchanged row can
# go without being re-written anyway (a safety net that also bounds worst-case
# staleness). Set 0 to force a write every cycle (the previous always-write
# behavior). Live-telemetry decoupling via Redis (next phase) builds on this.
PRINTER_PERSIST_MAX_INTERVAL_MS="30000"
# Poller refresh concurrency. Snapmaker/generic printers are polled over blocking
# HTTP (each up to PRINTER_REQUEST_TIMEOUT_MS), so when many are slow/offline a
# small worker pool serializes the cycle. 0 (default) auto-sizes the pool to the
# printer count, capped by _MAX; set an explicit number to pin it. If the poller
# logs "cycle overran", raise _MAX (more concurrent refreshes) or add a shard.
PRINTER_POLL_CONCURRENCY="0"
PRINTER_POLL_CONCURRENCY_MAX="64"
# Preventive-maintenance worker cadence (web service). The fleet-wide pass
# recomputes printer health scores, backfills schedules/events, and raises in-app
# maintenance notifications. Default 5 minutes; minimum 10s. Hour accrual + event
# creation happen in the poller as jobs finish — this is the un-sharded backstop.
MAINTENANCE_WORKER_INTERVAL_MS="300000"
# How often the web server evaluates Home Assistant ⇄ printer automation rules
# (Settings → Home Assistant). Detects printer-status / HA-entity transitions and
# fires the matching rule. Default 15s; minimum 5s.
HA_AUTOMATION_INTERVAL_MS="15000"
# Horizontal sharding. By default one poller owns every printer. To scale past a
# single process, run multiple poller services, each with the SAME
# POLLER_SHARD_COUNT and a DISTINCT POLLER_SHARD_INDEX (0..count-1): each replica
# deterministically owns a disjoint subset (crc32(id) % count), so there is no
# double-polling and each holds Bambu MQTT connections only for its own shard.
# Example for two shards — add a second poller service in docker-compose with
# POLLER_SHARD_COUNT=2 and POLLER_SHARD_INDEX=1 (the first uses index 0).
POLLER_SHARD_COUNT="1"
POLLER_SHARD_INDEX="0"
# Where the poller fetches Bambu camera snapshots for Discord notifications.
# Bambu cameras aren't plain HTTP, so the poller reuses the web service's
# /__printer_webcam/<id>/snapshot.jpg endpoint (default: the internal compose URL).
WEB_SNAPSHOT_BASE_URL="http://web:5173"

# Monitoring. Prometheus is no longer published on its own host port — nginx
# serves it under /prometheus on the main site, so an external Grafana uses
# http://<host>:HTTP_PORT/prometheus as a datasource. EXPORTER_PORT is internal
# only; if you change it, also update the scrape target in
# monitoring/prometheus/prometheus.yml.
EXPORTER_PORT="9180"
# Print requests are submitted through the in-app form at /request (the model
# file is stored in the database). The legacy Google Form/Sheet URLs in
# Settings → Integrations remain as an optional external link only.
#
# SSO sign-in (OAuth). Four providers are supported and can be enabled
# independently — all are configured at runtime in Settings → Sign-in (stored
# in DB); no restart required:
#   - Google:    create an OAuth client in the Google Cloud console; register
#                <origin>/api/auth/google/callback as an authorized redirect URI.
#   - Microsoft: register an app in the Azure portal (Entra ID → App
#                registrations), add a client secret, and register
#                <origin>/api/auth/microsoft/callback as a redirect URI. Microsoft
#                also needs the directory Tenant ID (a GUID, or "common"), OR — for
#                an on-prem AD FS server — set the authority URL to the /adfs deep
#                link (e.g. https://sso.example.com/adfs) instead of a tenant.
#   - ADFS:      Enter the authority base URL, Client ID, and Secret in
#                Settings → Sign-in → ADFS. The redirect_uri is fixed:
#                <origin>/api/auth/oauth2_redirect — register that with the IdP.
# Everyone who signs in via SSO gets the read-only "student" role.

# ─── Auto-update (admin "Update available" in Settings → Maintenance) ─────────
# On every push to main, .github/workflows/deploy.yml builds and pushes the app
# images to Docker Hub. These vars let a deployed site detect a newer published
# version and apply it with one click, without SSH.
#
# IMAGE_PREFIX — Docker Hub namespace the images were pushed under (the
# DOCKERHUB_USERNAME the workflow uses). Required only by docker-compose.deploy.yml
# (the production override that pulls images instead of building them):
#   docker compose -f docker-compose.yml -f docker-compose.deploy.yml up -d
# IMAGE_PREFIX="yourdockerhubuser"
#
# UPDATE_CHECK_REPO — "owner/repo" of this app on GitHub. Setting it turns on the
# update card: the server compares the running image's baked commit SHA against
# the latest commit on UPDATE_CHECK_BRANCH (default main). Empty = card hidden.
# UPDATE_CHECK_TOKEN is an optional GitHub token to lift the 60-req/hr
# unauthenticated rate limit or reach a private repo.
UPDATE_CHECK_REPO=""
UPDATE_CHECK_BRANCH="main"
UPDATE_CHECK_TOKEN=""
#
# WATCHTOWER_TOKEN — shared secret enabling one-click apply. The Watchtower
# sidecar (docker-compose.deploy.yml) authorizes update requests with it, and the
# web server presents it when the admin clicks "Update now". Empty = the button is
# hidden and the apply endpoint returns 503 (status-only). Generate a random value:
#   node -e "console.log(require('node:crypto').randomBytes(32).toString('hex'))"
WATCHTOWER_TOKEN=""
