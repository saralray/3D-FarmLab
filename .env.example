# Copy to .env and fill in. Only values that are REQUIRED or that must differ
# from a default belong here — the root .env is used solely for ${VAR}
# substitution in docker-compose.yml, and nearly every var there already has a
# ${VAR:-default}. To change a tunable not listed below (poll intervals, DB
# timeouts, log level, CSP/HSTS, ports, sharding, etc.), edit its default in
# docker-compose.yml directly; setting it here only works if compose references it.

# ── Required: Postgres credentials (no compose default) ──────────────────────
POSTGRES_DB="printfarm"
POSTGRES_USER="printfarm_app"
POSTGRES_PASSWORD="replace_with_a_long_random_password"

# ── Production deploy + one-click auto-update (docker-compose.deploy.yml) ─────
# IMAGE_PREFIX: Docker Hub namespace the CI workflow pushed images under.
# UPDATE_CHECK_REPO: "owner/repo" so the admin update card knows what to compare.
# WATCHTOWER_TOKEN: shared secret enabling one-click apply (empty = button hidden).
#   node -e "console.log(require('node:crypto').randomBytes(32).toString('hex'))"
# WATCHTOWER_DOCKER_SOCK: only needed on a rootless-Docker host — set it to the
#   per-user socket (`docker context ls`, usually /run/user/<uid>/docker.sock).
#   Left unset, Watchtower bind-mounts /var/run/docker.sock, which on a rootless
#   host is the wrong (rootful) socket and Watchtower can't reach it — it
#   crash-loops with "permission denied ... docker.sock".
IMAGE_PREFIX="yourdockerhubuser"
UPDATE_CHECK_REPO=""
WATCHTOWER_TOKEN=""
# WATCHTOWER_DOCKER_SOCK="/run/user/1000/docker.sock"
# On a dedicated deploy host (not a dev clone), uncomment this so plain
# `docker compose up`/`down`/`pull` always include docker-compose.deploy.yml —
# no more remembering `-f docker-compose.yml -f docker-compose.deploy.yml` (and
# no more `docker compose down` leaving watchtower running because it forgot
# about the override file). Compose reads COMPOSE_FILE straight out of .env.
# COMPOSE_FILE="docker-compose.yml:docker-compose.deploy.yml"

# ── Optional overrides (uncomment only to change from the default) ────────────
# Encrypt printer connection secrets at rest (AES-256-GCM). Must be identical on
# web, slicer-proxy AND poller. Empty = plaintext. Generate as above.
# PRINTER_SECRET_KEY=""
# Serve the session cookie as Secure once the site is behind HTTPS.
# SESSION_COOKIE_SECURE="true"
# Force a fixed public origin (OAuth/SAML redirects, slicer Device redirect).
# APP_BASE_URL="https://printfarm.example.com"
# Sign the slicer operator-grant token (shared web ⇄ slicer-proxy); empty = off.
# SLICER_GRANT_SECRET=""
# Auto-map slicer pushes onto the printer's AMS trays (material match, color
# preferred, fullest spool). "false" = always use the external spool instead.
# SLICER_AMS_AUTO="true"
# Redis cache/shared-counter in front of Postgres (optional; degrades gracefully).
# REDIS_URL="redis://redis:6379"
# L-1: require a Redis password so a co-located compromised container cannot
# read/flush rate-limit keys or sessions. When set, include it in REDIS_URL, e.g.
# REDIS_PASSWORD="replace_with_a_long_random_password"
REDIS_URL="redis://:replace_with_a_long_random_password@redis:6379"
# Leave REDIS_PASSWORD empty for a LAN-only deploy where the network is the boundary.
REDIS_PASSWORD="replace_with_a_long_random_password"
# Public-intake rate limit (queue submit / manager request): max requests per IP
# per window, and the window length in seconds. Defaults: 60 per 3600s. The
# default is generous because a whole class often submits from ONE public IP
# behind institutional NAT — a low cap would 429 legitimate print requests.
# Raise it further for large shared-NAT deployments; lower it to tighten abuse.
# PUBLIC_INTAKE_MAX_PER_WINDOW="60"
# PUBLIC_INTAKE_WINDOW_SECONDS="3600"
# Public viewer mode: redact printer connection details, disable controls.
# VITE_PUBLIC_VIEWER_MODE="true"
# DDoS / abuse mitigation at the nginx edge (L7): per-client-IP request rate,
# burst allowance, and max concurrent connections. Defaults are generous so a
# shared-NAT classroom isn't throttled; a real flood is still capped, and
# rejections return 429. A volumetric (L3/L4) DDoS needs an upstream CDN/scrubber
# in front of nginx — this protects the app tier, not the network pipe.
# RATE_LIMIT_REQ_RATE="50r/s"   # nginx units: r/s or r/m
# RATE_LIMIT_REQ_BURST="100"
# RATE_LIMIT_CONN="100"
# Prometheus is exposed at /prometheus on the public site for an external
# Grafana. Prometheus has no auth of its own (H-1), so set
# PROMETHEUS_BASIC_AUTH_PASSWORD to require HTTP Basic Auth on that route.
# Left unset (the default), /prometheus is served with NO auth — fine for a
# LAN-only deploy, but set a password before exposing this host publicly.
# An internal-network Grafana never needs this — it can reach
# http://prometheus:9090/prometheus directly with no credential either way.
# PROMETHEUS_BASIC_AUTH_USER="admin"
# PROMETHEUS_BASIC_AUTH_PASSWORD=""
# ESP32 status lights (per-printer RGB status lights). Each device joins WiFi
# and then polls GET /api/status-light/printers/<id> over normal HTTP(S) — the
# server URL and poll interval are written to the device at provisioning time
# from the printer page's flash dialog. No broker, no extra port, no shared
# credential (the status string carries no secrets). Set STATUS_LIGHT_ENABLED=
# false to turn the feature off (the provisioning endpoint then reports it
# disabled). STATUS_LIGHT_POLL_INTERVAL_MS is the default cadence suggested to
# the flash page; STATUS_LIGHT_STALE_MS is how long since a device's last poll
# before the dashboard shows it disconnected (default: 3× the poll interval).
# STATUS_LIGHT_ENABLED="true"
# STATUS_LIGHT_POLL_INTERVAL_MS="5000"
# STATUS_LIGHT_STALE_MS="15000"
# ── MCP server (LLM control surface over /api/v1) ────────────────────────────
# An 8th service exposing the farm's /api/v1 API as Model Context Protocol tools
# for an LLM client. Over HTTP (behind nginx at /mcp) the caller supplies their
# own printfarm_manage API key per request, so nothing extra is needed here. The
# vars below only matter if you change the defaults or run it over stdio.
# MCP_TRANSPORT="http"            # "stdio" for a local desktop client
# MCP_PORT="8092"
# PRINTFARM_API_BASE="http://web:5173"
# Only for MCP_TRANSPORT=stdio: the single printfarm_manage key the local server
# uses for every call (mint it in Settings → API Keys).
# PRINTFARM_API_KEY=""
