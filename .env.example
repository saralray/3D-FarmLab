POSTGRES_DB="printfarm"
POSTGRES_USER="printfarm_app"
POSTGRES_PASSWORD="replace_with_a_long_random_password"
HTTP_PORT="8080"
# nginx server_name. Leave as "_" to match any Host header, or set one or more
# space-separated names/IPs for name-based virtual hosting, e.g.
# "printfarm.example.com 203.0.113.5". Note: server_name matches the hostname
# only — the port is not part of it (that's HTTP_PORT above + "listen 80" in the
# container), so do not append ":port" here.
SERVER_NAME="_"
VITE_PUBLIC_VIEWER_MODE="false"

# Slicer-upload proxy. nginx routes /printers/ on the main site to this service,
# so a slicer (Orca etc.) can push sliced files using the same domain as the
# dashboard — point its OctoPrint host at http://<domain>/printers/<printerId>
# (no separate port). Authenticated with named API keys minted in Settings →
# Slicer Upload; the key is the only guard now that the endpoint is on the public
# site. SLICER_PROXY_PORT is still published for direct/legacy access and as a
# fallback — restrict it to the lab network, or drop the port mapping if you only
# use the nginx route.
SLICER_PROXY_PORT="8091"
# The slicer's "Device" tab opens its base URL, which redirects to the dashboard's
# printer-management page (with operator access). Behind nginx the redirect stays
# on the request's own domain automatically; set APP_BASE_URL only to force a
# specific origin, e.g. a different host or HTTPS scheme:
# APP_BASE_URL="https://printfarm.example.com"
APP_BASE_URL=""

PRINTER_OFFLINE_GRACE_SECONDS="30"
PRINTER_POLL_INTERVAL_MS="2000"
PRINTER_REQUEST_TIMEOUT_MS="3000"

# Monitoring. PROMETHEUS_PORT is published on the host so an external Grafana can
# use this Prometheus as a datasource (http://<host>:9090). EXPORTER_PORT is
# internal only; if you change it, also update the scrape target in
# monitoring/prometheus/prometheus.yml.
PROMETHEUS_PORT="9090"
EXPORTER_PORT="9180"
# The queue Google Sheet and print-request Google Form URLs are no longer set
# here. Configure them at runtime in Settings → Integrations (admin only);
# they are stored in the database.
