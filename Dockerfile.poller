FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

WORKDIR /app

COPY poller/requirements.txt ./requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

COPY poller ./poller

RUN groupadd --system poller \
  && useradd --system --gid poller --home-dir /app poller \
  && chown -R poller:poller /app

USER poller

CMD ["python", "poller/printer_status_poller.py"]
