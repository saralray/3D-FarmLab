{
  "__inputs": [],
  "__requires": [],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["printfarm"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Data source",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "3D-FarmLab",
  "uid": "printfarm-overview",
  "version": 1,
  "weekStart": "",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Printers",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "orientation": "auto", "textMode": "value", "colorMode": "value", "graphMode": "none", "justifyMode": "auto" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "printfarm_printers_total", "legendFormat": "printers", "instant": true }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Printers online",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "orientation": "auto", "textMode": "value", "colorMode": "value", "graphMode": "none", "justifyMode": "auto" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(printfarm_printer_up)", "legendFormat": "online", "instant": true }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Queued jobs",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "orientation": "auto", "textMode": "value", "colorMode": "value", "graphMode": "none", "justifyMode": "auto" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "printfarm_queue_jobs{state=\"queued\"}", "legendFormat": "queued", "instant": true }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Completed today",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "orientation": "auto", "textMode": "value", "colorMode": "value", "graphMode": "none", "justifyMode": "auto" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "printfarm_jobs_completed_today", "legendFormat": "completed", "instant": true }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Failed today",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "orientation": "auto", "textMode": "value", "colorMode": "value", "graphMode": "none", "justifyMode": "auto" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "printfarm_jobs_failed_today", "legendFormat": "failed", "instant": true }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Filament today",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "massg", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "orange", "value": null }] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "orientation": "auto", "textMode": "value", "colorMode": "value", "graphMode": "none", "justifyMode": "auto" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "printfarm_filament_grams_today", "legendFormat": "filament", "instant": true }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Nozzle temperature",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "celsius", "custom": { "drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "printfarm_printer_nozzle_temperature_celsius", "legendFormat": "{{name}}" }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Bed temperature",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "celsius", "custom": { "drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "printfarm_printer_bed_temperature_celsius", "legendFormat": "{{name}}" }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Print progress",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "printfarm_printer_progress_percent", "legendFormat": "{{name}}" }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Success rate",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "printfarm_printer_success_rate_percent", "legendFormat": "{{name}}" }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Jobs per hour",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "bars", "lineInterpolation": "linear", "fillOpacity": 60, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(increase(printfarm_jobs_completed_total[1h]))", "legendFormat": "completed" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(increase(printfarm_jobs_failed_total[1h]))", "legendFormat": "failed" }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Queue depth",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "lineInterpolation": "stepAfter", "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "printfarm_queue_jobs", "legendFormat": "{{state}}" }
      ]
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Print time per hour",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "fieldConfig": { "defaults": { "unit": "h", "custom": { "drawStyle": "bars", "lineInterpolation": "linear", "fillOpacity": 60, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(increase(printfarm_print_time_hours_total[1h]))", "legendFormat": "print hours" }
      ]
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Filament per hour",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "fieldConfig": { "defaults": { "unit": "massg", "custom": { "drawStyle": "bars", "lineInterpolation": "linear", "fillOpacity": 60, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(increase(printfarm_filament_grams_total[1h]))", "legendFormat": "filament" }
      ]
    },
    {
      "id": 15,
      "type": "table",
      "title": "Printer fleet",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 36 },
      "fieldConfig": { "defaults": { "custom": { "filterable": true } }, "overrides": [] },
      "options": { "showHeader": true },
      "transformations": [
        { "id": "labelsToFields", "options": {} },
        { "id": "organize", "options": { "excludeByName": { "Time": true, "Value": true, "__name__": true, "job": true, "instance": true } } }
      ],
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "printfarm_printer_info", "format": "table", "instant": true }
      ]
    },
    {
      "id": 16,
      "type": "timeseries",
      "title": "Live network throughput (web)",
      "description": "Current overall out/in traffic, derived from the web tier's raw per-request byte counters (printfarm_web job) — same live source as the Network Usage page's \"Live\" card, not the once-a-minute network_usage_daily-derived series.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 44 },
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(rate(printfarm_web_response_bytes_total[$__rate_interval]))", "legendFormat": "out" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(rate(printfarm_web_request_bytes_total[$__rate_interval]))", "legendFormat": "in" }
      ]
    }
  ]
}
